{
  "version": 2,
  "functions": {
    "server/index.js": {
      "includeFiles": "server/routes/**,server/prisma/**,server/ai/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/index.js" },
    { "source": "/(.*)", "destination": "/client/dist/$1" },
    { "source": "/(.*)", "destination": "/client/dist/index.html" }
  ]
}
